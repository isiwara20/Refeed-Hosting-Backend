{
  "name": "backend",
  "version": "1.0.0",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "cross-env NODE_ENV=test jest --runInBand",
    "test:unit": "cross-env NODE_ENV=test jest --runInBand --testPathPattern=auth|surplus|donation",
    "test:integration": "cross-env NODE_ENV=test jest --runInBand --testPathPattern=integration",
    "test:performance": "artillery run tests-donation/performance.yml",
    "test:ngo:unit": "cross-env NODE_ENV=test jest --runInBand test-ngo_userReg/simple.test.js",
    "test:ngo:integration": "cross-env NODE_ENV=test jest --runInBand test-ngo_userReg/api.realistic.test.js --testTimeout=30000",
    "test:ngo:endpoints": "cross-env NODE_ENV=test jest --runInBand test-ngo_userReg/api.realistic.test.js --testTimeout=30000",
    "test:ngo:all": "cross-env NODE_ENV=test jest --runInBand test-ngo_userReg/simple.test.js test-ngo_userReg/api.realistic.test.js test-ngo_userReg/performance.load.test.js --testTimeout=60000",
    "test:ngo:performance": "artillery run test-ngo_userReg/performance.yml",
    "test:admin:unit": "cross-env NODE_ENV=test jest --runInBand test-administration/simple.test.js",
    "test:admin:integration": "cross-env NODE_ENV=test jest --runInBand test-administration/integration.test.js --testTimeout=30000",
    "test:admin:performance": "cross-env NODE_ENV=test jest --runInBand test-administration/performance.load.test.js --testTimeout=60000",
    "test:admin:all": "cross-env NODE_ENV=test jest --runInBand test-administration/simple.test.js test-administration/integration.test.js test-administration/performance.load.test.js --testTimeout=60000",
    "test:notifymsg:integration": "cross-env NODE_ENV=test jest --runInBand test-notification-message/integration.test.js --testTimeout=30000",
    "test:notifymsg:junit": "cross-env NODE_ENV=test JEST_JUNIT_OUTPUT_DIR=./reports/junit JEST_JUNIT_OUTPUT_NAME=notification-message.junit.xml jest --runInBand test-notification-message/integration.test.js --testTimeout=30000 --reporters=default --reporters=jest-junit",
    "test:notifymsg:performance": "cross-env NODE_ENV=test jest --runInBand test-notification-message/performance.load.test.js --testTimeout=60000",
    "test:notifymsg:all": "npm run test:notifymsg:integration && npm run test:notifymsg:performance"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "axios": "^1.13.5",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "mongoose": "^9.1.6",
    "morgan": "^1.10.1",
    "pdfkit": "^0.17.2",
    "picomatch": "^4.0.4",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "babel-jest": "^29.7.0",
    "baseline-browser-mapping": "^2.10.13",
    "bcryptjs": "^3.0.3",
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "mongodb-memory-server": "^10.1.2",
    "nodemon": "^3.1.11",
    "supertest": "^7.0.0"
  }
}
