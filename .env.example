# ReFeed Backend Environment Variables

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/refeed

# Notification System Configuration  
NOTIFICATION_DEBUG=false
NOTIFICATION_RETRY_LIMIT=3

# Email Service Configuration (when implemented)
# EMAIL_SERVICE=sendgrid
# EMAIL_API_KEY=your_sendgrid_api_key
# EMAIL_FROM_ADDRESS=noreply@refeed.com
# EMAIL_FROM_NAME=ReFeed Team

# SMS Service Configuration (when implemented)
# SMS_SERVICE=twilio
# TWILIO_ACCOUNT_SID=your_twilio_sid
# TWILIO_AUTH_TOKEN=your_twilio_token
# TWILIO_PHONE_NUMBER=your_twilio_phone

# Application Configuration
NODE_ENV=development
PORT=3000

# Security
JWT_SECRET=your_jwt_secret_here
BCRYPT_ROUNDS=12

# File Upload (if needed)
# MAX_FILE_SIZE=5MB
# UPLOAD_PATH=./uploads